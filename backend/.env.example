# ============================================
# ElectionPulse SaaS - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-this-to-random-64-char-string
APP_DOMAIN=localhost

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://electionpulse:password@localhost:5432/electionpulse
DATABASE_ECHO=false

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# --- JWT Authentication ---
JWT_PRIVATE_KEY_PATH=keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=keys/jwt_public.pem
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Email (for verification) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@electionpulse.kr

# --- Naver API ---
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
NAVER_SEARCHAD_API_KEY=your-searchad-key
NAVER_SEARCHAD_SECRET=your-searchad-secret
NAVER_SEARCHAD_CUSTOMER_ID=your-customer-id

# --- Google/YouTube API ---
GOOGLE_API_KEY=your-google-api-key
YOUTUBE_API_KEY=your-youtube-api-key

# --- Kakao (geocoding + map heatmap) ---
KAKAO_REST_API_KEY=your-kakao-rest-key
KAKAO_JS_API_KEY=your-kakao-js-key

# --- KOSIS (Korean population stats — DT_1B04005N) ---
KOSIS_API_KEY=your-kosis-api-key

# --- Admin ---
ADMIN_EMAIL=admin@electionpulse.kr
ADMIN_INITIAL_PASSWORD=change-this-on-first-login

# --- Payments (TossPayments) ---
TOSS_CLIENT_KEY=your-toss-client-key
TOSS_SECRET_KEY=your-toss-secret-key

# --- Sentry (Error Tracking) ---
SENTRY_DSN=
