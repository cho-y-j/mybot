# ──── ElectionPulse 서버 환경변수 ────
# 이 파일을 .env.server로 복사 후 실제 값 입력
# cp .env.server.example .env.server

APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=your-secret-key-here

# ──── 네이버 API ────
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_SEARCHAD_API_KEY=
NAVER_SEARCHAD_SECRET=
NAVER_SEARCHAD_CUSTOMER_ID=

# ──── YouTube / Google ────
YOUTUBE_API_KEY=
GOOGLE_API_KEY=

# ──── 선관위 API ────
NEC_API_KEY=

# ──── Kakao (지오코딩 + 지도 히트맵) ────
KAKAO_REST_API_KEY=     # https://developers.kakao.com REST API 키 (백엔드 지오코딩)
KAKAO_JS_API_KEY=       # JavaScript 키 (프론트엔드 지도 렌더 — 공개됨)

# ──── KOSIS (국가통계포털 — 읍면동 인구) ────
KOSIS_API_KEY=          # https://kosis.kr/openapi DT_1B04005N (주민등록인구)

# ──── JWT 키 (서버에서 생성) ────
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ──── 관리자 ────
ADMIN_EMAIL=admin@naver.com
ADMIN_INITIAL_PASSWORD=Admin1234!

# ──── 결제 (선택) ────
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# ──── Meta 광고 (선택) ────
META_AD_LIBRARY_TOKEN=

# ──── SMTP (선택) ────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
